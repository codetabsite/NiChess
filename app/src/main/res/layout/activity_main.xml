<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="@color/bg_dark">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="NICHESS"
        android:textSize="36sp"
        android:textStyle="bold"
        android:letterSpacing="0.2"
        android:textColor="@color/text_primary"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Satranç"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="56dp" />

    <Button
        android:id="@+id/btn_vs_ai"
        style="@style/NichessButton"
        android:text="Yapay Zekaya Karşı" />

    <Button
        android:id="@+id/btn_bluetooth"
        style="@style/NichessButton.Secondary"
        android:layout_marginTop="12dp"
        android:text="Bluetooth ile Oyna" />

    <Button
        android:id="@+id/btn_local"
        style="@style/NichessButton.Secondary"
        android:layout_marginTop="12dp"
        android:text="Aynı Cihazda İki Kişi" />

</LinearLayout>
