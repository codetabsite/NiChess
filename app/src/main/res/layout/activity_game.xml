<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tv_black_elo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tv_secret_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EFSANE MOD"
            android:textColor="#FF0000"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.15"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tv_black_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="10:00"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:fontFamily="monospace" />

    </LinearLayout>

    <com.tdev.nichess.ui.board.BoardView
        android:id="@+id/board_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/top_bar"
        app:layout_constraintBottom_toTopOf="@id/bottom_bar"
        app:layout_constraintDimensionRatio="1:1" />

    <TextView
        android:id="@+id/tv_ai_thinking"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="düşünüyor..."
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/bottom_bar"
        app:layout_constraintStart_toStartOf="parent"
        android:paddingStart="16dp"
        android:paddingBottom="4dp" />

    <LinearLayout
        android:id="@+id/bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/tv_white_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="10:00"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:fontFamily="monospace" />

        <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />

        <TextView
            android:id="@+id/tv_white_elo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginEnd="16dp" />

        <Button
            android:id="@+id/btn_resign"
            style="@style/NichessButton.Danger"
            android:text="Teslim ol" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
